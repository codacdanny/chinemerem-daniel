# --- Contact form email delivery (Resend) ---
# 1. Create a free account at https://resend.com
# 2. Create an API key: https://resend.com/api-keys
# 3. Copy this file to `.env.local` and paste your key below.
RESEND_API_KEY=

# Where contact-form messages are delivered.
# IMPORTANT: with the test sender (onboarding@resend.dev) and no verified domain,
# Resend ONLY delivers to the exact email address your Resend account is signed up
# with. Set this to that address. To deliver anywhere else (e.g. a different inbox),
# verify a domain at resend.com/domains and set CONTACT_FROM to an address on it.
CONTACT_TO=your-resend-account-email@example.com

# Optional: once you verify your own domain in Resend, set a branded sender,
# e.g. "Chinemerem <hello@chinemerem.dev>". Otherwise leave unset.
# CONTACT_FROM=
